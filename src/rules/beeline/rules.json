{
  "operator": "beeline",
  "version": "1.0",
  "updated": "2025-06-13",
  "rules": {
    "font_rules": [
      {
        "id": "font-header-title",
        "description": "Шрифт названия сервиса в заголовке: Open Sans, не менее 22px — проверь вручную",
        "manual": true,
        "critical": true
      },
      {
        "id": "font-header-desc",
        "description": "Шрифт описания сервиса: Open Sans, не менее 18px — проверь вручную",
        "manual": true,
        "critical": true
      },
      {
        "id": "font-global-family",
        "description": "Основной шрифт страницы — Arial (кроме заголовка)",
        "property": "font-family",
        "must_contain": "arial",
        "critical": true,
        "manual": true
      },
      {
        "id": "font-global-min-size",
        "description": "Минимальный размер шрифта (кроме заголовков) 13px",
        "property": "font-size",
        "min_px": 13,
        "critical": true,
        "manual": true
      }
    ],
    "structure_rules": [
      {
        "id": "checkbox-exists",
        "description": "Чек-бокс input[type=checkbox] присутствует",
        "selector": "input[type='checkbox']",
        "must_exist": true,
        "critical": true
      },
      {
        "id": "exit-or-close",
        "description": "Наличие кнопки 'Выйти' или крестика для закрытия LP",
        "manual": true,
        "critical": true
      },
      {
        "id": "age-sign",
        "description": "Знак 18+ присутствует на странице",
        "selector": "body",
        "text_contains": "18+",
        "critical": true
      },
      {
        "id": "no-scroll",
        "description": "user-scalable=no в мета теге",
        "selector": "meta[name='viewport']",
        "attr_contains": {
          "attr": "content",
          "value": "user-scalable=no"
        },
        "critical": true
      },
      {
        "id": "static-price",
        "description": "Стоимость указана статично и контрастным цветом/заливкой",
        "manual": true,
        "critical": true
      },
      {
        "id": "no-misleading-phrases",
        "description": "Запрещены фразы: 'Нажми, чтобы продолжить', 'Видео готово' и подобные",
        "manual": true,
        "critical": true
      },
      {
        "id": "unique-lp",
        "description": "LP уникален (фон, кнопка, графика заменены)",
        "manual": true,
        "critical": true
      }
    ],
    "button_rules": [
      {
        "id": "btn-text-subscribe",
        "description": "Кнопка содержит слово 'Подключить'",
        "selector": "button, .button, .btn",
        "text_contains": "подключить",
        "critical": true
      },
      {
        "id": "btn-width",
        "description": "Ширина кнопки не более 80% от ширины LP — проверь вручную",
        "manual": true,
        "critical": true
      },
      {
        "id": "btn-height",
        "description": "Высота кнопки не более 25% от высоты LP — проверь вручную",
        "manual": true,
        "critical": true
      },
      {
        "id": "btn-clickarea",
        "description": "Кликабельная область кнопки — проверь вручную на 320x480",
        "manual": true,
        "critical": true
      },
      {
        "id": "btn-font-size",
        "description": "Размер шрифта кнопки не менее 20px — проверь вручную",
        "manual": true,
        "critical": true
      }
    ],
    "archive_rules": [
      {
        "id": "no-external-scripts",
        "description": "Нет внешних скриптов",
        "selector": "script[src^='http']",
        "must_not_exist": true,
        "critical": true
      },
      {
        "id": "no-external-styles",
        "description": "Нет внешних CSS",
        "selector": "link[href^='http']",
        "must_not_exist": true,
        "critical": true
      },
      {
        "id": "no-svg-xmlns",
        "description": "Нет xmlns атрибута в SVG",
        "selector": "svg[xmlns]",
        "must_not_exist": true,
        "critical": false
      },
      {
        "id": "img-alt",
        "description": "У всех изображений есть alt атрибут",
        "selector": "img",
        "all_must_have_attr": "alt",
        "critical": false
      }
    ],
    "css_rules": [
      {
        "id": "css-font-family",
        "description": "Основной шрифт — Arial (заголовки могут быть Open Sans)",
        "property": "font-family",
        "must_contain": "arial",
        "critical": false
      },
      {
        "id": "css-font-min-global",
        "description": "Все шрифты не менее 13px",
        "property": "font-size",
        "min_px": 13,
        "manual": true,
        "critical": true
      }
    ],
    "color_pairs": []
  }
}
